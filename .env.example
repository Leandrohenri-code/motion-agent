# Motion Agent — variaveis de ambiente
# Copie este arquivo para .env e preencha os valores necessarios
# As API keys NAO ficam aqui — elas sao salvas localmente em %USERPROFILE%\.motion-agent\.keys.json
# Este arquivo so e necessario para configuracoes de ambiente de desenvolvimento

# Ambiente
NODE_ENV=development

# Porta do servidor Vite (dev)
VITE_PORT=5173

# Caminho padrao do Python (se nao estiver no PATH do sistema)
# PYTHON_BIN=python
# PYTHON_BIN=C:\Users\SeuUsuario\AppData\Local\Programs\Python\Python314\python.exe
